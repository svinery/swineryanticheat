<Window x:Class="SwineryAntiCheat.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Swinery Anti-Cheat" Height="680" Width="920"
        MinHeight="560" MinWidth="780"
        WindowStartupLocation="CenterScreen" Background="#0b1020">

    <Window.Resources>
        <!-- Birincil (neon) buton -->
        <Style x:Key="NeonButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#00f3ff"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#00f3ff"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#00f3ff"/>
                                <Setter Property="Foreground" Value="#06121f"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- İkincil (ghost) buton -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="#14213d"/>
            <Setter Property="Foreground" Value="#cbd5e1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="14,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1e3a5f"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0b1020" Offset="0.0"/>
                <GradientStop Color="#15173a" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- başlık -->
            <RowDefinition Height="Auto"/>  <!-- kontrol şeridi -->
            <RowDefinition Height="*"/>     <!-- log -->
            <RowDefinition Height="Auto"/>  <!-- durum -->
        </Grid.RowDefinitions>

        <!-- ÜST BAŞLIK -->
        <Border Grid.Row="0" Padding="28,22,28,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#101935" Offset="0"/>
                    <GradientStop Color="#0b1020" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F6E1;" FontSize="30" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="SWINERY ANTI-CHEAT" Foreground="White" FontSize="30" FontWeight="Black" VerticalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00f3ff" BlurRadius="18" ShadowDepth="0"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>
                <TextBlock Text="Gelişmiş Hile Tespit Sistemi  •  İsim Entropisi + SHA256 + Imphash  •  v1.0"
                           Foreground="#7c89a8" FontSize="12.5" Margin="44,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- KONTROL ŞERİDİ -->
        <Grid Grid.Row="1" Margin="28,16,28,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BtnStartScan" Grid.Column="0" Content="TARAMAYI BAŞLAT"
                    Style="{StaticResource NeonButton}" Width="220" Height="50" Click="BtnStartScan_Click"/>

            <Button x:Name="BtnOpenReport" Grid.Column="1" Content="RAPORU AÇ"
                    Style="{StaticResource GhostButton}" Height="50" Margin="12,0,0,0"
                    IsEnabled="False" Click="BtnOpenReport_Click"/>

            <!-- Tehdit sayacı kartı -->
            <Border Grid.Column="3" CornerRadius="10" Padding="18,8" Background="#14213d" BorderBrush="#334155" BorderThickness="1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x26A0;" FontSize="18" Foreground="#fbbf24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="TESPİT EDİLEN TEHDİT" Foreground="#7c89a8" FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtThreatCount" Text="0" Foreground="#22c55e" FontSize="22" FontWeight="Black"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- CANLI LOG KARTI -->
        <Border Grid.Row="2" Background="#0c1226" CornerRadius="12" Margin="28,8,28,12" BorderBrush="#26304f" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#111a33" CornerRadius="12,12,0,0" Padding="16,9">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Fill="#22c55e" VerticalAlignment="Center"/>
                        <TextBlock Text="CANLI TARAMA GÜNLÜĞÜ" Foreground="#9fb0d0" FontSize="12" FontWeight="Bold" Margin="9,0,0,0"/>
                    </StackPanel>
                </Border>
                <RichTextBox x:Name="RtbLogs" Grid.Row="1" Background="Transparent" BorderThickness="0"
                             Foreground="#e2e8f0" FontSize="13.5" FontFamily="Cascadia Mono, Consolas"
                             IsReadOnly="True" VerticalScrollBarVisibility="Auto" Padding="14,10">
                    <FlowDocument>
                        <Paragraph x:Name="LogParagraph" LineHeight="18"/>
                    </FlowDocument>
                </RichTextBox>
            </Grid>
        </Border>

        <!-- DURUM ÇUBUĞU -->
        <Border Grid.Row="3" Background="#0a0f20" BorderBrush="#26304f" BorderThickness="0,1,0,0" Padding="24,0">
            <Grid Height="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Grid.Column="0" Text="Hazır." Foreground="#9fb0d0"
                           FontSize="13" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtPercent" Grid.Column="1" Text="%0" Foreground="#00f3ff"
                           FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ProgressBar x:Name="ScanProgressBar" Grid.Column="2" Width="220" Height="10"
                             Minimum="0" Maximum="100" Value="0"
                             Foreground="#00f3ff" Background="#1b2342" BorderThickness="0" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
