<Window x:Class="SwineryAntiCheat.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Swinery Anti-Cheat" Height="600" Width="800" WindowStartupLocation="CenterScreen" Background="#0f172a">
    <Window.Resources>
        <!-- Neon Buton Stili -->
        <Style x:Key="NeonButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#00f3ff"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#00f3ff"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00f3ff"/>
                    <Setter Property="Foreground" Value="#0f172a"/>
                    <Setter Property="BorderBrush" Value="#00f3ff"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Lacivert/Siyah Modern Arka Plan -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0f172a" Offset="0.0"/>
                <GradientStop Color="#1e1b4b" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <TextBlock Grid.Row="0" Text="SWINERY ANTI-CHEAT" Foreground="White" FontSize="36" FontWeight="Black" HorizontalAlignment="Center" Margin="0,30,0,10">
            <TextBlock.Effect>
                <!-- Neon Parlama Efekti -->
                <DropShadowEffect Color="#00f3ff" BlurRadius="20" ShadowDepth="0"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- Taramayı Başlat Butonu -->
        <Button x:Name="BtnStartScan" Grid.Row="1" Content="TARAMAYI BAŞLAT" Style="{StaticResource NeonButton}" Width="300" Height="60" Margin="0,20,0,20" Click="BtnStartScan_Click"/>

        <!-- Canlı Akış Log Alanı (RichTextBox) -->
        <Border Grid.Row="2" Background="#80000000" CornerRadius="10" Margin="30,10,30,20" BorderBrush="#33ffffff" BorderThickness="1">
            <RichTextBox x:Name="RtbLogs" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="14" FontFamily="Consolas" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Margin="10">
                <FlowDocument>
                    <Paragraph x:Name="LogParagraph"/>
                </FlowDocument>
            </RichTextBox>
        </Border>

        <!-- Durum Çubuğu (Status Bar) -->
        <StatusBar Grid.Row="3" Background="#1e293b" Foreground="White" Height="30">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="Hazır."/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar x:Name="ScanProgressBar" Width="200" Height="15" Minimum="0" Maximum="100" Value="0" Foreground="#00f3ff" Background="#0f172a" BorderThickness="0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
